from opcua import Client, ua
import time

PLC_URL = "opc.tcp://172.21.3.1:4840"
SIEMENS_URI = "http://www.siemens.com/simatic-s7-opcua"


class SubHandler:
    def datachange_notification(self, node, val, data):
        print(f"Data change event at {node}. New value = {val}")


if __name__ == "__main__":
    client = Client(PLC_URL)
    sub = None

    try:
        client.connect()
        print(f"Connected to {PLC_URL}")

        idx = client.get_namespace_index(SIEMENS_URI)
        print(f"Namespace index: {idx}")

        def n(s):
            return client.get_node(f'ns={idx};s={s}')

        nodes = {
            # Demo variables (must exist as OPCUA_data DB on PLC)
            "var1": n('"OPCUA_data"."var1"'),
            "var2": n('"OPCUA_data"."var2"'),
            "var3": n('"OPCUA_data"."var3"'),

            # abstractMachine [DB1] — matches screenshot exactly
            "appRun":       n('"abstractMachine"."appRun"'),
            "appDone":      n('"abstractMachine"."appDone"'),
            "awaitApp":     n('"abstractMachine"."awaitApp"'),
            "drillDone":    n('"abstractMachine"."drillDone"'),
            "sendTCPcmd":   n('"abstractMachine"."sendTCPcmd"'),
            "release":      n('"abstractMachine"."release"'),
            "taskCode":     n('"abstractMachine"."taskCode"'),

            # rfidControl [DB3] — matches screenshot exactly (camelCase)
            "doRead":           n('"rfidControl"."doRead"'),
            "readDone":         n('"rfidControl"."readDone"'),
            "readPresence":     n('"rfidControl"."readPresence"'),
            "doWrite":          n('"rfidControl"."doWrite"'),
            "writeDone":        n('"rfidControl"."writeDone"'),
            "writePresence":    n('"rfidControl"."writePresence"'),

            # identData [DB2] — matches screenshot exactly
            "readData":     n('"identData"."readData"'),
            "writeData":    n('"identData"."writeData"'),
        }

        def set_value(name, value):
            node = nodes.get(name)
            if node is None:
                print(f"Node '{name}' not found")
                return
            variant_type = node.get_data_type_as_variant_type()
            node.set_value(ua.DataValue(ua.Variant(value, variant_type)))

        def get_value(name):
            node = nodes.get(name)
            if node is None:
                print(f"Node '{name}' not found")
                return None
            return node.get_value()

        # Subscription
        handler = SubHandler()
        sub = client.create_subscription(500, handler)
        sub.subscribe_data_change(nodes["var1"])
        sub.subscribe_data_change(nodes["var2"])
        sub.subscribe_data_change(nodes["var3"])

        set_value("var3", [1, 2, 3, 4, 5, 6, 7, 8])

        # Initialize control flags
        set_value("appRun", False)
        set_value("appDone", False)

        def wait_for_rfid():
            if get_value("readDone"):
                rfid_data = get_value("readData")
                print(f"RFID read complete. Data: {rfid_data}")
                set_value("appRun", True)
                set_value("doRead", False)
                # readDone is reset by PLC on next cycle — do not reset here

        def wait_for_finish():
            if get_value("appDone"):
                print("Drilling complete, resetting flags")
                set_value("appRun", False)
                set_value("appDone", False)

        print("Running main loop...")
        while True:
            wait_for_rfid()
            wait_for_finish()
            time.sleep(0.1)

    except KeyboardInterrupt:
        print("Stopped by user")

    finally:
        if sub is not None:
            sub.delete()
        client.disconnect()
        print("Disconnected from PLC")